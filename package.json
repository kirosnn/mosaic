{
  "name": "@kirosnn/mosaic",
  "productName": "Mosaic",
  "version": "0.8.0",
  "description": "The open source coding agent.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "bin": {
    "mosaic": "bin/mosaic.cjs"
  },
  "files": [
    "bin",
    "src/app",
    "src/index.tsx",
    "src/agent",
    "src/auth",
    "src/components",
    "src/mcp",
    "src/utils",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "!src/**/__tests__",
    "!src/**/__tests__/**"
  ],
  "scripts": {
    "dev": "bun run --watch src/app/cli/main.tsx",
    "mosaic": "bun run src/app/cli/main.tsx",
    "start": "bun run src/app/cli/main.tsx",
    "desktop:dev": "bun run desktop/scripts/dev.ts",
    "desktop:start": "bun run desktop/scripts/start.ts",
    "desktop:build": "bun run desktop/scripts/build.ts",
    "lint": "bunx tsc -p tsconfig.json --noEmit",
    "lint:desktop": "bunx tsc -p desktop/tsconfig.json --noEmit",
    "lint:desktop-main": "bunx tsc -p desktop/tsconfig.main.json --noEmit",
    "test": "bun test"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^37.2.0",
    "vite": "^7.1.3",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/mistral": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/xai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@mozilla/readability": "^0.6.0",
    "@opentui/core": "^0.1.81",
    "@opentui/react": "^0.1.81",
    "ai": "^4.0.0",
    "ai-sdk-openai-websocket-fetch": "^1.0.0",
    "better-sqlite3": "^12.6.0",
    "groq-sdk": "^0.37.0",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.575.0",
    "ollama": "^0.5.0",
    "opentui-spinner": "^0.0.6",
    "playwright": "^1.45.0",
    "react": "19.2.4",
    "react-doctor": "^0.0.17",
    "react-dom": "19.2.4",
    "react-syntax-highlighter": "^16.1.0",
    "simple-icons": "^16.9.0",
    "turndown": "^7.2.2",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  }
}
